rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // User profile document permissions: only the matching authenticated user can read/write their own profile
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }
    
    // Datasets permissions: users can read/write only their own dataset document listings
    match /datasets/{datasetId} {
      allow read, update, delete: if request.auth != null && request.auth.uid == resource.data.userId;
      allow create: if request.auth != null && request.auth.uid == request.resource.data.userId;
    }
    
    // Analysis history logs: users can read/write only their own historical actions records
    match /analysisHistory/{analysisId} {
      allow read, update, delete: if request.auth != null && request.auth.uid == resource.data.userId;
      allow create: if request.auth != null && request.auth.uid == request.resource.data.userId;
    }
  }
}
